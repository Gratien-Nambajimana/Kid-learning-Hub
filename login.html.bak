<!DOCTYPE html>
<html>

<head>
    <title>Kids Learning Hub - Login</title>
    <link rel="stylesheet" href="styles.css">
</head>

<body class="hero">

<header>
    Kids Learning Hub Login
</header>

<nav>
    <a href="WEB.html">Home</a>
    <a href="Register.html">Register</a>
    <a href="login.html">Login</a>
    <a href="admin.html">Admin Panel</a>
	 <a href="courses.html">Courses</a>
</nav>

<div class="login-container">

    <!-- USER LOGIN -->
    <div class="login-box">

        <h2>User Login</h2>

        <form>

            Email:<br>
            <input type="email"
            placeholder="Enter your email">

            <br><br>

            Password:<br>
            <input type="password"
            placeholder="Enter password">

            <br><br>

            <a href="courses.html">
    <button type="button">Login as User</button>
</a>
        </form>

    </div>

    <!-- ADMIN LOGIN -->
    <div class="login-box">

        <h2>Admin Login</h2>

        <form>

            Admin Username:<br>
            <input type="text"
            placeholder="Enter admin username">

            <br><br>

            Password:<br>
            <input type="password"
            placeholder="Enter admin password">

            <br><br>

            <a href="admin.html">
    <button type="button">Login as Admin</button>
</a>

        </form>

    </div>

</div>

<footer>
    © 2026 Kids Learning Hub
</footer>

</body>
</html>